{
  "name": "@network-chess/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "tsx watch src/index.ts",
