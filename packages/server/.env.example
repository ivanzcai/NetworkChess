# Postgres connection string. Defaults to local Postgres on docker-compose.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chess?schema=public

# Server port (defaults to 3001)
PORT=3001

# Auth: passwordless magic link via Resend.
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=
# "From" address must be on a domain you have verified in the Resend dashboard.
# In dev (no RESEND_API_KEY), the code is logged to stdout and returned in the
# /api/auth/magic-link/request response so the UI can display it inline.
RESEND_FROM_ADDRESS=SkyMate <onboarding@resend.dev>
RESEND_FROM_NAME=SkyMate

# Auth: Google OAuth.
# 1. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
#    Application type: "Web application".
#
# 2. ⚠️  This is the field that bit me before. There are TWO similar-sounding
#     fields on the OAuth client config. They are NOT interchangeable:
#
#       • "Authorized JavaScript origins" -- e.g. http://localhost:5173.
#         This is for CORS on XHR/fetch from your frontend. The values you
#         pasted here are fine for that, but they DO NOT cover OAuth.
#
#       • "Authorized redirect URIs"      -- e.g. http://localhost:3001/api/auth/oauth/google/callback
#         This is the URL Google will send the user back to after consent.
#         It MUST match the URL the server actually generates (see
#         OAUTH_REDIRECT_BASE below); otherwise Google returns a
#         redirect_uri_mismatch error and the user lands back on the app
#         with ?error=... in the URL.
#
#     Add both a dev entry AND a prod entry (your Cloud Run URL):
#       - http://localhost:3001/api/auth/oauth/google/callback
#       - https://<your-cloud-run-url>/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#
# OAUTH_REDIRECT_BASE is the public URL where Google reaches your callback.
# The server concatenates "/api/auth/oauth/google/callback" onto this.
#
# • Dev  → http://localhost:3001  (the express server, NOT the vite port)
# • Prod → https://<your-cloud-run-url>
OAUTH_REDIRECT_BASE=http://localhost:3001
#
# PUBLIC_BASE_URL is where the SPA actually lives -- where the browser
# should end up after the OAuth callback completes. Must differ from
# OAUTH_REDIRECT_BASE in dev (vite serves the SPA on 5173) and equal it
# in prod (single Cloud Run origin serves both API + SPA).
#
# • Dev  → http://localhost:5173
# • Prod → https://<your-cloud-run-url>
PUBLIC_BASE_URL=http://localhost:5173

# Dev fallbacks: when NODE_ENV is not "production" the server exposes
# /api/auth/magic-link/request (returns the code inline) and /api/auth/dev/login
# (permits signing in as any email/displayName). Both are disabled in production.
NODE_ENV=development
